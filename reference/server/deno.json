{
  "name": "@repo/reference-server",
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@remix-run/component"
  },
  "imports": {
    "@remix-run/component": "npm:@remix-run/component@^0.6.0",
    "@remix-run/component/server": "npm:@remix-run/component@^0.6.0/server",
    "@remix-run/component/jsx-runtime": "npm:@remix-run/component@^0.6.0/jsx-runtime",
    "@remix-run/fetch-router": "npm:@remix-run/fetch-router",
    "@remix-run/html-template": "npm:@remix-run/html-template",
    "@remix-run/static-middleware": "npm:@remix-run/static-middleware",
    "@remix-run/cors-middleware": "npm:@remix-run/cors-middleware",
    "@remix-run/logger-middleware": "npm:@remix-run/logger-middleware"
  },
  "tasks": {
    "dev": "deno task build && deno run -A --watch ./server/mod.ts",
    "start": "deno run -A ./server/mod.ts"
  }
}
