{
  "tasks": {
    "check": "deno check; deno lint; deno test -P; deno fmt --check",
    "bundle": "deno task --cwd ../bundler build",
    "dev": "deno task bundle && deno serve -P --watch ./router.ts",
    "serve": "deno serve -P ./router.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@remix-run/ui"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "jose": "jsr:@panva/jose@^6.2.3",
    "@libsql/client": "npm:@libsql/client@^0.17.4",
    "@remix-run/ui": "npm:@remix-run/ui@^0.4.0",
    "@remix-run/cors-middleware": "npm:@remix-run/cors-middleware@0.1.7",
    "@remix-run/fetch-router": "npm:@remix-run/fetch-router@0.20.1",
    "@remix-run/logger-middleware": "npm:@remix-run/logger-middleware@0.3.4",
    "@remix-run/html-template": "npm:@remix-run/html-template@0.3.1",
    "@remix-run/response": "npm:@remix-run/response@0.3.7",
    "@remix-run/session": "npm:@remix-run/session@^0.4.2",
    "@remix-run/static-middleware": "npm:@remix-run/static-middleware@0.4.13"
  },
  "permissions": {
    "default": {
      "env": [
        "IDP_ORIGIN",
        "RP_ORIGIN",
        "RP_SIGNING_KEY_JWK",
        "TURSO_DATABASE_URL",
        "TURSO_AUTH_TOKEN"
      ],
      "net": ["id.kbn.one", "localhost", "127.0.0.1"],
      "read": ["../bundled"]
    }
  }
}
